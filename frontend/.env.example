# true のときセッション延長（POST /refresh）をスキップ（バックエンド DEBUG モードと併用）
VITE_DEBUG=false

# 本番用 API 基点（末尾スラッシュなし）
VITE_MOVIE_ORIGIN=https://example.com/api/v1/movie
VITE_LOGIN_ORIGIN=https://example.com/api/auth

# 開発時プロキシ先（省略時 http://127.0.0.1:8000）
# VITE_MOVIE_PROXY_TARGET=http://127.0.0.1:8000
# VITE_LOGIN_PROXY_TARGET=http://127.0.0.1:8001
